{
  "private": true,
  "scripts": {
    "clean": "git clean -Xdf",
    "all": "turbo run --ui tui build format test lint attw license-header",
    "setversion": "node scripts/set-workspace-version.js",
    "postsetversion": "npm run all",
    "release": "npm run all && node scripts/release.js",
    "format": "biome format --write",
    "license-header": "license-header --ignore 'packages/**'",
    "lint": "biome lint --error-on-warnings"
  },
  "workspaces": ["packages/validate", "packages/example"],
  "type": "module",
  "packageManager": "npm@10.9.0",
  "licenseHeader": {
    "licenseType": "apache",
    "yearRange": "2025",
    "copyrightHolder": "The Connect Authors"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^1.9.4",
    "@bufbuild/buf": "^1.57.2",
    "@bufbuild/license-header": "^0.0.4",
    "@bufbuild/protoc-gen-es": "^2.6.3",
    "@types/node": "^24.2.1",
    "tsx": "^4.20.3",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3"
  }
}
